# --- LLM (local via Ollama; no API key needed) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
LLM_TIMEOUT_SECONDS=180

# --- Hard budget (assignment constraints) ---
MAX_LLM_CALLS=10
MAX_COST_USD=0.20
# Local model is free, so cost is SIMULATED from real token counts:
MOCK_PRICE_PER_1K_TOKENS=0.01

# --- Web search ---
# DuckDuckGo needs no API key. If you swap in a paid provider (e.g. Tavily),
# put its key here and it will be injected into the container via --env-file:
# SEARCH_API_KEY=your-key-here
